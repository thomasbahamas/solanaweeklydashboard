# Solana Weekly Dashboard - Environment Variables
# Copy to .env and fill in values

# Claude API (for The Signal narrative generation)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# CryptoPanic (for news aggregation)
CRYPTOPANIC_API_KEY=xxxxx

# Telegram delivery (optional)
TELEGRAM_BOT_TOKEN=xxxxx
TELEGRAM_CHAT_ID=xxxxx

# Solana RPC (optional - uses public RPC if not set)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# CoinGecko (optional — free tier, CoinPaprika used as fallback)
COINGECKO_API_KEY=xxxxx

# GitHub Pages URL (for Telegram link)
GITHUB_PAGES_URL=https://solanaweekly.io

# Kit (ConvertKit) — newsletter
KIT_API_KEY=kit_xxxxx
KIT_FORM_ID=9240695
